<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjetoExtensao.Configuracoes"
             Title="Configurações"
             BackgroundColor="AliceBlue">

    <VerticalStackLayout Spacing="20" Padding="0">

        <Grid ColumnDefinitions="Auto,*,Auto">
            <Label Text="Configurações"
                   Margin="10 0 0 0"
                   Grid.Column="1"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   TextColor="Black"
                   FontSize="18"/>
        </Grid>

        <VerticalStackLayout HorizontalOptions="Center" Spacing="8">
            <AbsoluteLayout WidthRequest="120" HeightRequest="120">
                <Frame AbsoluteLayout.LayoutBounds="0.5,0.5,100,100"
                       AbsoluteLayout.LayoutFlags="PositionProportional"
                       CornerRadius="50"
                       BackgroundColor="#EAF4FF"
                       HasShadow="False"
                       HorizontalOptions="Center"
                       VerticalOptions="Center">
                    <Image Source="dotnet_bot.png" Aspect="AspectFill" />
                </Frame>

                <Frame AbsoluteLayout.LayoutBounds="0.75,0.75,36,36"
                       AbsoluteLayout.LayoutFlags="PositionProportional"
                       CornerRadius="18"
                       BackgroundColor="#4DA2FF"
                       HasShadow="False">
                    <ImageButton Source="edit_icon.png"
                                 BackgroundColor="Transparent"
                                 WidthRequest="20"
                                 HeightRequest="20" />
                </Frame>
            </AbsoluteLayout>

            <Label x:Name="lblUsuarioLogado"
                   FontAttributes="Bold"
                   FontSize="18"
                   TextColor="Black"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <VerticalStackLayout Margin="20" Spacing="0">
            <Grid Padding="14" ColumnDefinitions="*,Auto">
                <Label Text="Tipo de eventos" VerticalOptions="Center" TextColor="Black" FontSize="20"/>
                <Label Text="›" 
                       Grid.Column="1" 
                       VerticalOptions="Center" 
                       HorizontalOptions="End" 
                       TextColor="Black"
                       FontSize="30"/>
            </Grid>
            <BoxView HeightRequest="1" Color="Black" />

            <Grid Padding="14" ColumnDefinitions="*,Auto">
                <Label Text="Eventos" VerticalOptions="Center" TextColor="Black" FontSize="20" />
                <Label Text="›" Grid.Column="1" VerticalOptions="Center" TextColor="Black" FontSize="30" />
            </Grid>
            <BoxView HeightRequest="1" Color="Black" />

            <Grid Padding="14" ColumnDefinitions="*,Auto">
                <Label Text="Notificação" VerticalOptions="Center" TextColor="Black" FontSize="20" />
                <Label Text="›" Grid.Column="1" VerticalOptions="Center" TextColor="Black" FontSize="30" />
            </Grid>
            <BoxView HeightRequest="1" Color="Black" />

            <Grid Padding="14" ColumnDefinitions="*,Auto">
                <Label Text="Aparência" VerticalOptions="Center" TextColor="Black" FontSize="20" />
                <Label Text="›" Grid.Column="1" VerticalOptions="Center" TextColor="Black" FontSize="30" />
            </Grid>
            <BoxView HeightRequest="1" Color="Black" />

            <Grid Padding="14" ColumnDefinitions="*,Auto">
                <Label Text="Privacidade e segurança" VerticalOptions="Center" TextColor="Black" FontSize="20" />
                <Label Text="›" Grid.Column="1" VerticalOptions="Center" TextColor="Black" FontSize="30" />
            </Grid>
        </VerticalStackLayout>

        <!-- Logout button at bottom -->
        <Button x:Name="btnVoltar"
            Text="Voltar"
            BackgroundColor="#087AFE"
            WidthRequest="200"
            Clicked="BotaoVoltar_Clicked"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            FontSize="20"/>

        <Button Text="Desconectar"
                Clicked="BotaoSair_Clicked"
                BackgroundColor="Transparent"
                TextColor="#007AFF"
                HorizontalOptions="Center"
                Margin="-5 0 0 0" 
                FontSize="16"/>

    </VerticalStackLayout>

</ContentPage>